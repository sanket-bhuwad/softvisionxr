# Mail server configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@example.com
MAIL_PASS=your-app-password

# Where contact form emails will be delivered
CONTACT_TO_EMAIL=info@softvisionxr.com

# Optional sender identity
CONTACT_FROM_NAME=SOFTVISIONXR Website

# Backend server configuration
PORT=3000
ALLOWED_ORIGIN=http://localhost:4200

# Google auth configuration for backend verification
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Optional: comma-separated admin emails. If set, other verified Google users can login as viewer role.
ADMIN_EMAILS=

# Demo password-login credentials (used by /api/auth/demo)
DEMO_ADMIN_EMAIL=admin@softvisionxr.com
DEMO_ADMIN_PASSWORD=Admin@123
